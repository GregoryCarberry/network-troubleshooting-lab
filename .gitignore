##################################################
# OS / Editor Junk
##################################################

.DS_Store
Thumbs.db
*.swp
*.swo
.vscode/
.idea/

##################################################
# Python
##################################################

__pycache__/
*.pyc
*.pyo
*.pyd
*.pytest_cache/
*.coverage
htmlcov/

##################################################
# Archives / Backups
##################################################

*.zip
*.tar
*.tar.gz
*.tgz
*.bak
*.old

##################################################
# Lab Device Config Safety (CRITICAL)
##################################################

# Never commit raw device backups
configs/**/*working-config*.tar.gz
configs/**/*running-config*.txt
configs/**/*startup-config*.txt
configs/**/*backup*.tar.gz
configs/**/*full-config*.tar.gz

# OpenWrt sensitive exports
configs/**/wireless.conf
configs/**/shadow
configs/**/passwd

# Keys & Certificates
**/*.key
**/*.pem
**/*.crt
**/*.p12
**/*.pfx
**/*ssh_host_*

##################################################
# SSH / Secrets
##################################################

id_rsa
id_ed25519
*.env
.env

##################################################
# Temporary Lab Output / Testing
##################################################

*.pcap
*.log
*.tmp
*.cache

##################################################
# Future-proofing
##################################################

# If you later add monitoring exports
exports/
dumps/
snapshots/